# Dbmate lee DATABASE_URL para conectarse.
# Construye la URL a partir de tus variables PG existentes en .env,
# o declárala directamente aquí.
#
# Ejemplo (ajusta usuario y contraseña):
#   DATABASE_URL="postgres://postgres:tu_password@127.0.0.1:5432/bari_lms"
#
# Si ya tienes las variables PGUSER, PGPASSWORD, etc. en .env, puedes
# ejecutar dbmate pasando la URL directamente:
#   dbmate --url "postgres://$PGUSER:$PGPASSWORD@$PGHOST:$PGPORT/$PGDATABASE" up
